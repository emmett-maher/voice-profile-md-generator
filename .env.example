# ──────────────────────────────────────────────────────────────────────────
# Voice Profile MD Generator — environment configuration
#
# A fresh clone runs with NO keys at all: `npm install && npm run dev` boots
# into labelled demo mode (seeded fictional creators + a replayable recorded
# synthesis run). Fill in the variables below to unlock the full
# ingest → synthesize → export flow on your own content.
# ──────────────────────────────────────────────────────────────────────────

# ---- Next.js app (this file → .env) ---------------------------------------

# Convex deployment URL (printed by `npx convex dev`), e.g. https://….convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# Auth.js — generate with `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# RS256 private key bridging Auth.js sessions to Convex.
# Generate with: npm run generate-keys   (paste the printed line here)
CONVEX_AUTH_PRIVATE_KEY=

# Public URL of this app (used as the JWT issuer; default http://localhost:3000)
SITE_URL=http://localhost:3000

# ---- Convex deployment (set with `npx convex env set KEY value`) -----------
# These run server-side in Convex actions, NOT in Next.js:
#
#   ANTHROPIC_API_KEY   – required for synthesis (claude-opus-4-8 draft,
#                         claude-sonnet-4-6 repair, claude-haiku-4-5-20251001
#                         segmentation/classification)
#   DEEPGRAM_API_KEY    – optional; speech-to-text fallback for audio without
#                         captions (model defaults to nova-3, override with
#                         DEEPGRAM_MODEL)
#   RESEND_API_KEY      – optional; emails you when a long run completes
#                         (falls back to in-app notifications)
#   RESEND_FROM         – optional; verified sender address for Resend
#   SITE_URL            – required; must match SITE_URL above so Convex can
#                         validate the app's JWTs via /api/auth/jwks
